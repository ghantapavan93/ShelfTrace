# Database
DATABASE_URL=postgresql+psycopg2://shelftrace:shelftrace@postgres:5432/shelftrace_db

# Redis
REDIS_URL=redis://redis:6379/0

# Demo mode (enables /api/v1/demo/reset and auto-seed on boot)
DEMO_MODE=true

# Backend
BACKEND_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000

# Logging
LOG_LEVEL=info
