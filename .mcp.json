{
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://shelftrace:shelftrace@localhost:5432/shelftrace_db"
      ]
    },
    "sqlite-dev": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-sqlite",
        "--db-path",
        "./backend/shelftrace_dev.db"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "shelftrace": {
      "command": "python",
      "args": ["-m", "app.mcp_server"],
      "env": {
        "PYTHONPATH": "backend",
        "DATABASE_URL": "sqlite:///./backend/shelftrace_dev.db"
      }
    }
  }
}
